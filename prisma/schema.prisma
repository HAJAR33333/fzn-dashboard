// generator et datasource
generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 1. Modèle Utilisateur (Enrichi avec les nouveaux champs)
model User {
  id       String  @id @default(cuid())
  email    String  @unique // Email professionnel
  password String?

  // Identité
  nom         String?
  prenom      String? // Ajouté
  telephone   String? // Ajouté (10 chiffres)
  fonction    String? // Ajouté (Titre du poste)
  dateArrivee DateTime? // Date à laquelle l'employé a rejoint l'entreprise

  // Statut
  isActive Boolean @default(true) // true = Actif, false = Inactif (Archivé)

  // Véhicule
  puissanceFiscale Int? // Puissance fiscale (CV) pour le barème IK

  role      Role     @default(OWNER)
  createdAt DateTime @default(now())

  // Relations
  espacesOwned  Espace[] @relation("OwnerRelation")
  espaceId      String?
  espaceTravail Espace?  @relation("CollaborateurRelation", fields: [espaceId], references: [id])

  // NOUVEAU : Relation avec les frais
  fraisKilometriques FraisKilometrique[]
}

// 2. Gestion Multi-Sociétés (Espaces)
model Espace {
  id             String  @id @default(cuid())
  nom            String // Dénomination sociale
  siret          String  @unique
  formeJuridique String? // SARL, SAS, etc.

  // Dirigeant
  dirigeantPrenom String?
  dirigeantNom    String?

  // Adresse Siège
  adresse    String?
  codePostal String?
  ville      String?
  pays       String? @default("France")

  // Contact
  email     String?
  telephone String?

  couleur   String?  @default("#3b82f6")
  createdAt DateTime @default(now())

  // --- RELATIONS UTILISATEURS ---
  // Le propriétaire unique
  userId String?
  owner  User?   @relation("OwnerRelation", fields: [userId], references: [id])

  // La liste des salariés / utilisateurs secondaires
  collaborateurs User[] @relation("CollaborateurRelation")

  // --- BUSINESS LOGIC ---
  exercices          Exercice[]
  clients            Client[]
  factures           Facture[]
  fraisKilometriques FraisKilometrique[]
}

// 3. Exercice Comptable
model Exercice {
  id        String   @id @default(cuid())
  code      String // ex: 2025
  dateDebut DateTime
  dateFin   DateTime
  isActif   Boolean  @default(false)
  objectif  Float    @default(0)

  espaceId String
  espace   Espace @relation(fields: [espaceId], references: [id])

  factures Facture[]

  @@unique([code, espaceId])
}

// 4. Modèle Client
model Client {
  id             String  @id @default(cuid())
  nom            String // Nom de l'entreprise
  formeJuridique String?
  contactPrenom  String?
  contactNom     String?
  adresse        String?
  codePostal     String?
  ville          String?
  pays           String? @default("France")
  siret          String?
  email          String?
  telephone      String?
  statutClient   String? // ex: Prospect, Client actif

  espaceId String
  espace   Espace    @relation(fields: [espaceId], references: [id])
  factures Facture[]
}

// 5. Modèle Devis & Factures
model Facture {
  id           String        @id @default(cuid())
  numero       String // ex: DEV-2025-001
  type         DocumentType  @default(DEVIS)
  statut       StatutFacture @default(BROUILLON)
  dateEmission DateTime      @default(now())
  dateEcheance DateTime?

  montantHT  Float @default(0)
  montantTVA Float @default(0)
  totalTTC   Float @default(0)

  espaceId String
  espace   Espace @relation(fields: [espaceId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  exerciceId String
  exercice   Exercice @relation(fields: [exerciceId], references: [id])

  lignes LigneFacture[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 6. Détail des lignes
model LigneFacture {
  id           String @id @default(cuid())
  designation  String
  quantite     Float  @default(1)
  prixUnitaire Float
  remise       Float  @default(0)
  tva          Float  @default(20)

  factureId String
  facture   Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
}

model FraisKilometrique {
  id        String      @id @default(cuid())
  date      DateTime    @default(now())
  clientNom String
  distance  Float
  taux      Float
  montant   Float
  statut    StatutFrais @default(EN_ATTENTE)

  // Relation avec l'utilisateur
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relation avec l'espace
  espaceId String
  espace   Espace @relation(fields: [espaceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- AJOUT AUX ENUMS EXISTANTS ---

enum StatutFrais {
  EN_ATTENTE
  VALIDE
  REMBOURSE
  REFUSE
}

// --- ENUMS ---

enum DocumentType {
  DEVIS
  FACTURE
}

enum StatutFacture {
  BROUILLON
  VALIDE
  PAYE
  ANNULE
}

enum Role {
  OWNER // Le créateur
  MANAGER // Manager
  COLLABORATEUR // Au lieu de USER
}
